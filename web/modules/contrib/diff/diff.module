<?php

/**
 * @file
 */

declare(strict_types=1);

use Drupal\Core\Hook\Attribute\LegacyHook;
use Drupal\Core\Routing\RouteMatchInterface;
use Drupal\diff\Hook\DiffHelpHooks;
use Drupal\diff\Hook\DiffViewsHooks;

/**
 * Implements hook_help().
 */
#[LegacyHook]
function diff_help($route_name, RouteMatchInterface $route_match): string {
  return \Drupal::service(DiffHelpHooks::class)->help($route_name, $route_match);
}

/**
 * Implements hook_views_data().
 */
#[LegacyHook]
function diff_views_data(): array {
  return \Drupal::service(DiffViewsHooks::class)->viewsData();
}
